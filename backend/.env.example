# Copy this file to .env and fill in your values
# Never commit the actual .env file to GitHub

# ── Database ─────────────────────────────────────────────────
# Local development (SQLite):
# DATABASE_URL=sqlite:///./busihub.db
#
# Production (Neon PostgreSQL — get this from neon.tech dashboard):
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Security ──────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-this-with-a-long-random-secret-key

# ── CORS — your Vercel frontend URL ───────────────────────────
# Local: http://localhost:5173
# Production: https://your-app-name.vercel.app
API_ORIGINS=["http://localhost:5173","https://your-app-name.vercel.app"]

# ── Cookie security ───────────────────────────────────────────
# Set to true in production (requires HTTPS)
USE_SECURE_COOKIES=true
